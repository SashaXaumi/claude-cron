{
  "name": "claude-cron",
  "version": "0.1.0",
  "private": true,
  "license": "CC-BY-NC-4.0",
  "description": "A Cloudflare Worker that runs versioned watch/digest jobs from D1 on a daily cron and emails the user when something fires. No fetch handler. No bot. Managed by a human talking to a Claude that can reach their Cloudflare.",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "schema:local": "wrangler d1 execute claude-cron --local --file=schema.sql",
    "schema:remote": "wrangler d1 execute claude-cron --remote --file=schema.sql",
    "types": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "marked": "^14.1.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.91.0"
  }
}
